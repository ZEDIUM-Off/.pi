{
  "lastChangelogVersion": "0.80.10",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "high",
  "treeFilterMode": "default",
  "theme": "dark",
  "npmCommand": [
    "pnpm",
    "--config.dangerously-allow-all-builds=true"
  ],
  "packages": [
    "npm:pi-web-access",
    "npm:pi-skill-palette",
    "npm:pi-tool-display",
    "npm:pi-rtk-optimizer",
    "npm:pi-smart-fetch",
    "npm:@kaiserlich-dev/pi-session-search",
    "npm:pi-peon-ping",
    "npm:@calesennett/pi-codex-usage",
    "npm:@nonplanarslicer/pi-save-output",
    "https://github.com/omaclaren/pi-studio",
    "git:github.com/DietrichGebert/ponytail",
    "npm:@a-fig/accordion",
    "git:https://github.com/nicobailon/pi-subagents",
    "git:github.com/ZEDIUM-Off/pi-runtime-monitor",
    "npm:pi-intercom@0.6.0"
  ],
  "quietStartup": true,
  "pi-codex-usage": {
    "usageMode": "left",
    "refreshWindow": "7d"
  },
  "terminal": {
    "showTerminalProgress": false
  },
  "enabledModels": [
    "openai-codex/gpt-5.6-terra",
    "openai-codex/gpt-5.6-sol",
    "openai-codex/gpt-5.6-luna",
    "openai-codex/gpt-5.5"
  ]
}
